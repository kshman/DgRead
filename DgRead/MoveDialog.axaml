<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:DgRead"
        mc:Ignorable="d"
        x:Class="DgRead.MoveDialog"
        Width="560"
        Height="650"
        MinWidth="460"
        MinHeight="460"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="12" RowSpacing="8">
        <TextBlock x:Name="GuideTextBlock"
                   Grid.Row="0"
                   FontSize="14" />

        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="Gray" Padding="4,0,4,4">
            <Grid ColumnDefinitions="56,160,*">
                <TextBlock x:Name="NoHeaderTextBlock" Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <TextBlock x:Name="AliasHeaderTextBlock" Grid.Column="1" />
                <TextBlock x:Name="DirectoryHeaderTextBlock" Grid.Column="2" />
            </Grid>
        </Border>

        <ListBox x:Name="MoveListBox"
                 Grid.Row="2"
                 SelectionMode="Single"
                  DragDrop.AllowDrop="True"
                  PointerPressed="OnMoveListPointerPressed"
                  PointerMoved="OnMoveListPointerMoved"
                  DragDrop.DragOver="OnMoveListDragOver"
                  DragDrop.Drop="OnMoveListDrop"
                 DoubleTapped="OnMoveListDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:MoveDialogItem">
                    <Grid ColumnDefinitions="56,160,*" Margin="4,2">
                        <TextBlock Grid.Column="0" Text="{Binding No}" HorizontalAlignment="Right" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Alias}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="2" Text="{Binding FolderDisplay}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Button x:Name="BrowseButton" Grid.Column="0" MinWidth="90" Click="OnBrowseClick" />
            <TextBox x:Name="DestTextBox" Grid.Column="1" />
            <Button x:Name="AddLocationButton" Grid.Column="2" MinWidth="100" Click="OnAddLocationClick" />
        </Grid>

        <Grid Grid.Row="4" ColumnDefinitions="Auto,2*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBlock x:Name="AliasLabelTextBlock" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="AliasTextBox" Grid.Column="1" />
            <Button x:Name="ApplyAliasButton" Grid.Column="2" MinWidth="100" HorizontalAlignment="Center" Click="OnApplyAliasClick" />
            <Button x:Name="MoveUpButton" Grid.Column="3" Width="34" Height="30" Click="OnMoveUpClick">
                <PathIcon Width="14" Height="14" Data="M3 11 L8 4 L13 11 Z" />
            </Button>
            <Button x:Name="MoveDownButton" Grid.Column="4" Width="34" Height="30" Click="OnMoveDownClick">
                <PathIcon Width="14" Height="14" Data="M3 5 L8 12 L13 5 Z" />
            </Button>
            <Button x:Name="DeleteLocationButton" Grid.Column="5" Width="34" Height="30" Click="OnDeleteLocationClick">
                <PathIcon Width="14" Height="14" Data="M5 4 L11 4 L11 3 L13 3 L13 5 L3 5 L3 3 L5 3 Z M4 6 L12 6 L11.5 13 L4.5 13 Z" />
            </Button>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="OkButton" MinWidth="120" IsDefault="True" HorizontalContentAlignment="Center" Click="OnOkClick" />
            <Button x:Name="CancelButton" MinWidth="90" HorizontalContentAlignment="Center" Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
