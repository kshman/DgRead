<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="using:DgRead" mc:Ignorable="d" x:Class="DgRead.BookmarkWindow" Width="700" Height="600" MinWidth="460" MinHeight="360" ShowInTaskbar="False" WindowStartupLocation="CenterOwner" CanResize="True">
    <Grid RowDefinitions="Auto,Auto,*" Margin="12" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock x:Name="TitleTextBlock" Grid.Column="0" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
            <Button x:Name="CheckFilesButton" Grid.Column="1" Width="34" Height="30" Click="OnCheckFilesClick">
                <PathIcon Width="15" Height="15" Data="M3 8.5 L6.8 12 L14 4.5 L15.5 6 L6.8 14.5 L1.5 9.7 Z" />
            </Button>
        </Grid>
        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="Gray" Padding="4,0,4,4">
            <Grid ColumnDefinitions="*,80,150" ColumnSpacing="8">
                <TextBlock x:Name="FilenameHeaderTextBlock" Grid.Column="0" />
                <TextBlock x:Name="PageHeaderTextBlock" Grid.Column="1" HorizontalAlignment="Right" />
                <TextBlock x:Name="CreatedHeaderTextBlock" Grid.Column="2" HorizontalAlignment="Right" />
            </Grid>
        </Border>
        <ListBox x:Name="BookmarkListBox" Grid.Row="2" SelectionMode="Single" DoubleTapped="OnBookmarkListDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:BookmarkListItem">
                    <Grid ColumnDefinitions="*,80,150" ColumnSpacing="8" Margin="4,2">
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" Foreground="{Binding FileNameBrush}" />
                            <TextBlock Text="{Binding PathText}" FontSize="9" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding PageText}" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="{Binding CreatedText}" HorizontalAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>

